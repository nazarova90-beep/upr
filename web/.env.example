# UPR web — пример переменных окружения.
# Скопировать в .env.local при необходимости. .env* (кроме .env.example) в репо не коммитятся.
# Реальные секреты сюда НЕ кладём — это публичный шаблон.

# Базовый URL бэкенда. Нужен только если обходим Vite proxy.
# По умолчанию Vite проксирует /api/* → http://localhost:8000 (см. vite.config.ts).
# VITE_API_BASE_URL=http://localhost:8000

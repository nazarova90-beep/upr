# Пример переменных окружения для мобильного приложения UPR.
# Скопируй этот файл в `.env` и заполни значения.
#
# В Expo переменные с префиксом `EXPO_PUBLIC_` доступны в коде через
# `process.env.EXPO_PUBLIC_*` и попадают в бандл клиента, поэтому
# секретов сюда класть НЕЛЬЗЯ — только публичные ссылки и ключи.
# См. docs/references/expo.md.

# Базовый URL бэкенда. На локали это адрес FastAPI-сервера в той же сети,
# что и iPhone (Expo Go). Точное значение появится на шаге hello-world.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

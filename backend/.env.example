# UPR backend — пример переменных окружения.
# Копируем в .env и заполняем реальными значениями. .env в репозиторий не коммитится (см. .gitignore).
# Реальные секреты сюда НЕ кладём — это публичный шаблон.

# Подключение к базе данных. На MVP — локальный SQLite.
# Будущее: postgresql+psycopg://user:pass@host:5432/upr
UPR_DATABASE_URL=sqlite:///./upr.db

# Уровень логирования: debug | info | warning | error.
UPR_LOG_LEVEL=info

# AI-провайдер: gemini | local. Для MVP — gemini.
# Сам ключ Gemini добавится при подключении провайдера (Phase 2 / thin slice):
# UPR_GEMINI_API_KEY=...
UPR_AI_PROVIDER=gemini

# Локальная папка для видео (используется реализацией storage/local.py).
UPR_LOCAL_STORAGE_DIR=./var/videos
